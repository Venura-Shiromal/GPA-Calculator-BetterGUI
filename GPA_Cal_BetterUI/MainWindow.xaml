<Window Style="{DynamicResource WindowStyle1}" x:Class="GPA_Cal_BetterUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GPA_Cal_BetterUI"
        Title="GPA Calculator" 
        Height="450" Width="280" 
        ResizeMode="NoResize" 
        Opacity="0.95"
        FontFamily="Bahnschrift" 
        WindowStyle="None" 
        Background="Transparent"
        AllowsTransparency="True" 
        Foreground="Transparent"
        >

    <Window.Resources>
        <Style x:Key="RoundedLabel" TargetType="Label">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#FF302B3C"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Label">
                        <Border Background="{TemplateBinding Background}" 
                        CornerRadius="5,5,15,15"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RoundedComboBox" TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#FF302B3C"/>
            <Setter Property="BorderBrush" Value="#FF403B55"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- Main rounded border -->
                            <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10"
                            SnapsToDevicePixels="True"/>

                            <!-- Selected item display -->
                            <ContentPresenter x:Name="ContentSite"
                                      Margin="6,0,25,0"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Left"
                                      Content="{TemplateBinding SelectionBoxItem}"
                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                      SnapsToDevicePixels="True"/>

                            <!-- Single toggle button for dropdown arrow -->
                            <ToggleButton x:Name="DropDownToggle"
                                  Background="Transparent"
                                  BorderBrush="{x:Null}"
                                  Focusable="False"
                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                  HorizontalAlignment="Right"
                                  Width="20"
                                  Margin="0,2,9,2">
                                <Path Fill="#FF0F0E11" Data="M 0 0 L 4 4 L 8 0 Z"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </ToggleButton>

                            <!-- Dropdown popup -->
                            <Popup x:Name="PART_Popup"
                           Placement="Bottom"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           AllowsTransparency="True"
                           Focusable="False"
                           PopupAnimation="Slide" RenderTransformOrigin="0.5,0.5">
                                <Border Background="#FF2C2835"
                                BorderBrush="#FF2C2835"
                                BorderThickness="1"
                                CornerRadius="5">
                                    <ScrollViewer CanContentScroll="True">
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <!-- Hover and disabled triggers -->
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FF403B55"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Background" Value="#FF1E1C25"/>
                                <Setter Property="Foreground" Value="#FF2C2835"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ButtonStyle1" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#FF302B3C"/>
            <Setter Property="BorderBrush" Value="#FF302B3C"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                        Background="{TemplateBinding Background}" 
                        BorderBrush="{TemplateBinding BorderBrush}" 
                        BorderThickness="{TemplateBinding BorderThickness}" 
                        CornerRadius="15" 
                        SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" 
                                      VerticalAlignment="Center" 
                                      RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF403B55"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF403B55"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF565075"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF565075"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#FF1E1C25"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF1E1C25"/>
                                <Setter Property="Foreground" Value="#FF555555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="WindowStyle1" TargetType="{x:Type Window}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Window}">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ExitButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent">
                            <TextBlock x:Name="PART_Text"
                                   Text="✕"
                                   FontSize="16"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PART_Text" Property="Foreground" Value="Red"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="PART_Text" Property="Foreground" Value="#AAFF0000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="20,20,20,20" Background="#FF0E0D11" MouseDown="Window_MouseDown" SnapsToDevicePixels="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="26*"/>
                <ColumnDefinition Width="9*"/>
            </Grid.ColumnDefinitions>
            <Button Style="{DynamicResource ButtonStyle1}" x:Name="Cal_Button" Content="Calculate" Click="Button_Click" Foreground="White" Background="#FF302B3C" FontSize="16" Margin="91,316,19,91"/>
            <Border Margin="29,47,93,158">
                <Grid Margin="0,0,-10,0">
                    <Label Content="Mathematics&#xD;&#xA;" HorizontalAlignment="Center" VerticalAlignment="Top" Foreground="White" FontSize="14" RenderTransformOrigin="1.071,-0.418" Width="106" Height="29"/>
                    <Label Content="Programming&#xA;" HorizontalAlignment="Center" Margin="0,42,0,0" VerticalAlignment="Top" Foreground="White" FontSize="14" RenderTransformOrigin="1.071,-0.418" Width="106" Height="29"/>
                    <Label Content="Electrical&#xA;" Margin="-6,84,6,0" VerticalAlignment="Top" Foreground="White" FontSize="14" RenderTransformOrigin="1.071,-0.418" Height="29"/>
                    <Label Content="Material&#xA;" HorizontalAlignment="Center" Margin="0,128,0,0" VerticalAlignment="Top" Foreground="White" FontSize="14" RenderTransformOrigin="1.071,-0.418" Width="106" Height="29"/>
                    <Label Content="Fluid&#xA;" HorizontalAlignment="Center" Margin="0,172,0,0" VerticalAlignment="Top" Foreground="White" FontSize="14" RenderTransformOrigin="1.071,-0.418" Width="106" Height="29"/>
                    <Label Content="Mechanics&#xA;" HorizontalAlignment="Center" Margin="0,216,0,0" VerticalAlignment="Top" Foreground="White" FontSize="14" RenderTransformOrigin="1.071,-0.418" Width="106" Height="29"/>

                </Grid>
            </Border>
            <ComboBox x:Name="Grade_Maths" 
                Style="{StaticResource RoundedComboBox}"
                HorizontalAlignment="Left" 
                Margin="185,45,0,0" 
                VerticalAlignment="Top" 
                Width="58" 
                Height="26" 
                SelectedIndex="-1" 
                FontSize="14" 
                BorderBrush="{x:Null}" Background="#FF2C2835" Foreground="White" Grid.ColumnSpan="2">

                <ComboBoxItem Content="A+"/>
                <ComboBoxItem Content="A"/>
                <ComboBoxItem Content="A-"/>
                <ComboBoxItem Content="B+"/>
                <ComboBoxItem Content="B"/>
                <ComboBoxItem Content="B-"/>
                <ComboBoxItem Content="C+"/>
                <ComboBoxItem Content="C"/>
                <ComboBoxItem Content="C-"/>
                <ComboBoxItem Content="D"/>
                <ComboBoxItem Content="F"/>

            </ComboBox>
            <ComboBox x:Name="Grade_CS" 
                Style="{StaticResource RoundedComboBox}"
                HorizontalAlignment="Left" 
                Margin="185,91,0,0" 
                VerticalAlignment="Top" 
                Width="58" 
                Height="26" 
                SelectedIndex="-1" 
                FontSize="14" 
                BorderBrush="{x:Null}" Background="#FF2C2835" Foreground="White" Grid.ColumnSpan="2">

                <ComboBoxItem Content="A+"/>
                <ComboBoxItem Content="A"/>
                <ComboBoxItem Content="A-"/>
                <ComboBoxItem Content="B+"/>
                <ComboBoxItem Content="B"/>
                <ComboBoxItem Content="B-"/>
                <ComboBoxItem Content="C+"/>
                <ComboBoxItem Content="C"/>
                <ComboBoxItem Content="C-"/>
                <ComboBoxItem Content="D"/>
                <ComboBoxItem Content="F"/>

            </ComboBox>
            <ComboBox x:Name="Grade_Elec" 
                Style="{StaticResource RoundedComboBox}"
                HorizontalAlignment="Left" 
                Margin="185,133,0,0"
                VerticalAlignment="Top" 
                Width="58" 
                Height="26" 
                SelectedIndex="-1" 
                FontSize="14" 
                BorderBrush="{x:Null}" Background="#FF2C2835" Foreground="White" Grid.ColumnSpan="2">

                <ComboBoxItem Content="A+"/>
                <ComboBoxItem Content="A"/>
                <ComboBoxItem Content="A-"/>
                <ComboBoxItem Content="B+"/>
                <ComboBoxItem Content="B"/>
                <ComboBoxItem Content="B-"/>
                <ComboBoxItem Content="C+"/>
                <ComboBoxItem Content="C"/>
                <ComboBoxItem Content="C-"/>
                <ComboBoxItem Content="D"/>
                <ComboBoxItem Content="F"/>

            </ComboBox>
            <ComboBox x:Name="Grade_Mat" 
                Style="{StaticResource RoundedComboBox}"
                HorizontalAlignment="Left" 
                Margin="185,173,0,0" 
                VerticalAlignment="Top" 
                Width="58" 
                Height="26" 
                SelectedIndex="-1" 
                FontSize="14" 
                BorderBrush="{x:Null}" Background="#FF2C2835" Foreground="White" Grid.ColumnSpan="2">

                <ComboBoxItem Content="A+"/>
                <ComboBoxItem Content="A"/>
                <ComboBoxItem Content="A-"/>
                <ComboBoxItem Content="B+"/>
                <ComboBoxItem Content="B"/>
                <ComboBoxItem Content="B-"/>
                <ComboBoxItem Content="C+"/>
                <ComboBoxItem Content="C"/>
                <ComboBoxItem Content="C-"/>
                <ComboBoxItem Content="D"/>
                <ComboBoxItem Content="F"/>

            </ComboBox>
            <ComboBox x:Name="Grade_Fluid" 
                Style="{StaticResource RoundedComboBox}"
                HorizontalAlignment="Left" 
                Margin="185,217,0,0" 
                VerticalAlignment="Top" 
                Width="58" 
                Height="26" 
                SelectedIndex="-1" 
                FontSize="14" 
                BorderBrush="{x:Null}" Background="#FF2C2835" Foreground="White" Grid.ColumnSpan="2">

                <ComboBoxItem Content="A+"/>
                <ComboBoxItem Content="A"/>
                <ComboBoxItem Content="A-"/>
                <ComboBoxItem Content="B+"/>
                <ComboBoxItem Content="B"/>
                <ComboBoxItem Content="B-"/>
                <ComboBoxItem Content="C+"/>
                <ComboBoxItem Content="C"/>
                <ComboBoxItem Content="C-"/>
                <ComboBoxItem Content="D"/>
                <ComboBoxItem Content="F"/>

            </ComboBox>
            <ComboBox x:Name="Grade_Mech" 
                Style="{StaticResource RoundedComboBox}"
                HorizontalAlignment="Left" 
                Margin="185,262,0,0" 
                VerticalAlignment="Top" 
                Width="58" 
                Height="26" 
                SelectedIndex="-1" 
                FontSize="14" 
                BorderBrush="{x:Null}" Background="#FF2C2835" Foreground="White" Grid.ColumnSpan="2">

                <ComboBoxItem Content="A+"/>
                <ComboBoxItem Content="A"/>
                <ComboBoxItem Content="A-"/>
                <ComboBoxItem Content="B+"/>
                <ComboBoxItem Content="B"/>
                <ComboBoxItem Content="B-"/>
                <ComboBoxItem Content="C+"/>
                <ComboBoxItem Content="C"/>
                <ComboBoxItem Content="C-"/>
                <ComboBoxItem Content="D"/>
                <ComboBoxItem Content="F"/>

            </ComboBox>
            <Label x:Name="Result" 
                   Style="{StaticResource RoundedLabel}" 
                   Content="" 
                   HorizontalAlignment="Left" 
                   Margin="10,382,0,0" 
                   VerticalAlignment="Top" 
                   Width="260" Height="59" 
                   Background="#7F2C2835" 
                   Foreground="White" 
                   FontSize="18" 
                   FontFamily="Bahnschrift SemiBold" Grid.ColumnSpan="2" >
            </Label>
            <Button Style="{StaticResource ExitButtonStyle}"
                    Width="30" Height="30"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,10,10,0"
                    Click="ExitButton_Click" Grid.Column="1"/>
        </Grid>
    </Border>
</Window>
