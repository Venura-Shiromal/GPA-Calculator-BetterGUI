                        <ComboBoxItem Content="B-"/>
                        <ComboBoxItem Content="C+"/>
                        <ComboBoxItem Content="C"/>
                        <ComboBoxItem Content="C-"/>
                        <ComboBoxItem Content="D"/>
                        <ComboBoxItem Content="F"/>
                    </ComboBox>
                    <ComboBox x:Name="Grade_CS_S2" Style="{StaticResource RoundedComboBox}" HorizontalAlignment="Left" Margin="234,123,0,0" VerticalAlignment="Top" Width="58" Height="26" SelectedIndex="-1" FontSize="14" BorderBrush="{x:Null}" Background="#FF2C2835" Foreground="White">
                        <ComboBoxItem Content="A+"/>
                        <ComboBoxItem Content="A"/>
                        <ComboBoxItem Content="A-"/>
                        <ComboBoxItem Content="B+"/>
                        <ComboBoxItem Content="B"/>
                        <ComboBoxItem Content="B-"/>
                        <ComboBoxItem Content="C+"/>
                        <ComboBoxItem Content="C"/>
                        <ComboBoxItem Content="C-"/>
                        <ComboBoxItem Content="D"/>
                        <ComboBoxItem Content="F"/>
                    </ComboBox>
                    <ComboBox x:Name="Grade_Elec_S2" Style="{StaticResource RoundedComboBox}" HorizontalAlignment="Left" Margin="234,165,0,0" VerticalAlignment="Top" Width="58" Height="26" SelectedIndex="-1" FontSize="14" BorderBrush="{x:Null}" Background="#FF2C2835" Foreground="White">
                        <ComboBoxItem Content="A+"/>
                        <ComboBoxItem Content="A"/>
                        <ComboBoxItem Content="A-"/>
                        <ComboBoxItem Content="B+"/>
                        <ComboBoxItem Content="B"/>
                        <ComboBoxItem Content="B-"/>
                        <ComboBoxItem Content="C+"/>
                        <ComboBoxItem Content="C"/>
                        <ComboBoxItem Content="C-"/>
                        <ComboBoxItem Content="D"/>
                        <ComboBoxItem Content="F"/>
                    </ComboBox>
                    <ComboBox x:Name="Grade_Mat_S2" Style="{StaticResource RoundedComboBox}" HorizontalAlignment="Left" Margin="234,209,0,0" VerticalAlignment="Top" Width="58" Height="26" SelectedIndex="-1" FontSize="14" BorderBrush="{x:Null}" Background="#FF2C2835" Foreground="White">
                        <ComboBoxItem Content="A+"/>
                        <ComboBoxItem Content="A"/>
                        <ComboBoxItem Content="A-"/>
                        <ComboBoxItem Content="B+"/>
                        <ComboBoxItem Content="B"/>
                        <ComboBoxItem Content="B-"/>
                        <ComboBoxItem Content="C+"/>
                        <ComboBoxItem Content="C"/>
                        <ComboBoxItem Content="C-"/>
                        <ComboBoxItem Content="D"/>
                        <ComboBoxItem Content="F"/>
                    </ComboBox>
                    <ComboBox x:Name="Grade_Fluid_S2" Style="{StaticResource RoundedComboBox}" HorizontalAlignment="Left" Margin="234,253,0,0" VerticalAlignment="Top" Width="58" Height="26" SelectedIndex="-1" FontSize="14" BorderBrush="{x:Null}" Background="#FF2C2835" Foreground="White">
                        <ComboBoxItem Content="A+"/>
                        <ComboBoxItem Content="A"/>
                        <ComboBoxItem Content="A-"/>
                        <ComboBoxItem Content="B+"/>
                        <ComboBoxItem Content="B"/>
                        <ComboBoxItem Content="B-"/>
                        <ComboBoxItem Content="C+"/>
                        <ComboBoxItem Content="C"/>
                        <ComboBoxItem Content="C-"/>
                        <ComboBoxItem Content="D"/>
                        <ComboBoxItem Content="F"/>
                    </ComboBox>
                    <ComboBox x:Name="Grade_Mech_S2" Style="{StaticResource RoundedComboBox}" HorizontalAlignment="Left" Margin="234,296,0,0" VerticalAlignment="Top" Width="58" Height="26" SelectedIndex="-1" FontSize="14" BorderBrush="{x:Null}" Background="#FF2C2835" Foreground="White">
                        <ComboBoxItem Content="A+"/>
                        <ComboBoxItem Content="A"/>
                        <ComboBoxItem Content="A-"/>
                        <ComboBoxItem Content="B+"/>
                        <ComboBoxItem Content="B"/>
                        <ComboBoxItem Content="B-"/>
                        <ComboBoxItem Content="C+"/>
                        <ComboBoxItem Content="C"/>
                        <ComboBoxItem Content="C-"/>
                        <ComboBoxItem Content="D"/>
                        <ComboBoxItem Content="F"/>
                    </ComboBox>

                    <ComboBox x:Name="Department" 
                              Style="{StaticResource RoundedComboBoxWithWatermark}"
                              HorizontalAlignment="Center" 
                              Margin="0,21,0,0" 
                              VerticalAlignment="Top" 
                              Width="152" 
                              Height="26" 
                              SelectedIndex="-1" 
                              FontSize="14" 
                              BorderBrush="{x:Null}" Background="#FF2C2835" Foreground="White"
                              SelectionChanged="Department_SelectionChanged">
                        <ComboBoxItem Content="Electrical"/>
                        <ComboBoxItem Content="In Development..."/>
                    </ComboBox>
                </Grid>

                <!-- Shared Calculate button and Result label -->
                <Button Style="{DynamicResource ButtonStyle1}" x:Name="Cal_Button" Content="Calculate" Click="Button_Click" Foreground="White" Background="#FF302B3C" FontSize="16" Margin="100,420,100,101"/>
                <Label x:Name="Result" Style="{StaticResource RoundedLabel}" Content="" HorizontalAlignment="Center" Margin="0,482,0,0" VerticalAlignment="Top" Width="330" Height="71" Background="#7F2C2835" Foreground="White" FontSize="18" FontFamily="Bahnschrift SemiBold"/>
                <Button Style="{StaticResource ExitButtonStyle}" Width="30" Height="30" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,10,10,0" Click="ExitButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>